{
  "name": "ug-file",
  "version": "0.3.0",
  "description": "Unofficial SDK for UGOS Pro file management APIs.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "license": "MIT",
  "author": "TsFreddie",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TsFreddie/ug-file.git"
  },
  "bugs": {
    "url": "https://github.com/TsFreddie/ug-file/issues"
  },
  "keywords": [
    "ugreen",
    "ugos",
    "ugos-pro",
    "nas",
    "file-management",
    "sdk",
    "ugreen-nas",
    "ugos-api"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun run build:types && bun run build:bundle",
    "build:bundle": "bun build ./src/index.ts --outdir ./dist",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
